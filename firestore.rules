
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles: Only the owner can read or write their own profile
    match /user_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Students collection: Users can only see and manage their own student records
    match /students/{studentId} {
      // Allow read if the existing document belongs to the user
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow create if the user is assigning the record to themselves
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Allow update and delete if the user owns the document
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Subscriptions collection: Users can only see and manage their own subscriptions
    match /subscriptions/{subscriptionId} {
      // Allow read if the existing document belongs to the user
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow create if the user is assigning the record to themselves
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Allow update and delete if the user owns the document
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Deny all other access by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
