
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "fullName", "email"]
    },
    "Student": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The owner of this student record" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "name"]
    },
    "Subscription": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "type": { "type": "string", "description": "e.g., Yoga, Karate" },
        "sessionsTotal": { "type": "integer" },
        "sessionsUsed": { "type": "integer" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "expired", "completed"] }
      },
      "required": ["userId", "studentId", "sessionsTotal", "sessionsUsed"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/user_profiles/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/students/{studentId}", "definition": { "entityName": "Student" } },
      { "path": "/subscriptions/{subscriptionId}", "definition": { "entityName": "Subscription" } }
    ],
    "reasoning": "Standard user-owned data structure. All documents include a userId field for security filtering."
  }
}
